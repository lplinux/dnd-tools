# ─── D&D Tools — Environment Configuration ───────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────
# Option A: full connection string (takes precedence if set)
# DATABASE_URL=postgres://dndtools:dndtools123@localhost:5432/dndtools

# Option B: individual fields (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=dndtools
DB_PASSWORD=dndtools123
DB_NAME=dndtools

# ── App ───────────────────────────────────────────────────────
# Secret used to sign session cookies — change this to a long random string
SESSION_SECRET=change-me-to-something-long-and-random

# HTTP port the Node.js server listens on (default: 3080)
# PORT=3080
